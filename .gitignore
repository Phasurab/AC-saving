# ═══════════════════════════════════════════════════════════════
# Hotel Occupancy Detection System — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Large Data Files ─────────────────────────────────────────
*.csv
*.parquet
*.h5
*.hdf5
!data/external/th_holiday_event_macro_features.csv

# ── Model Weights ────────────────────────────────────────────
*.txt
!requirements.txt
!README.md
*.pt
*.pth
*.pkl
*.joblib
*.onnx
*.bin

# ── Reports / PDFs ───────────────────────────────────────────
*.pdf

# ── Jupyter Notebook Checkpoints ─────────────────────────────
.ipynb_checkpoints/
__pycache__/
*.pyc
*.pyo

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Python Environments ──────────────────────────────────────
.venv/
venv/
env/
.conda/
*.egg-info/
dist/
build/

# ── Misc ─────────────────────────────────────────────────────
*.log
*.tmp
.temp-repair/
